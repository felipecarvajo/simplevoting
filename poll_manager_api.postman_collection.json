      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/polls/questions",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "polls",
            "questions"
          ]
        },
        "description": "Returns a JSON array with all active polls."
      },
      "response": [
